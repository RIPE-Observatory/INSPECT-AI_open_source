{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["apps/ui/.next/**", "apps/ui/out/**"]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "biome.json",
        "bunfig.toml",
        "package.json",
        "turbo.json",
        "pyrightconfig.json"
      ],
      "outputs": []
    },
    "format": {
      "dependsOn": ["^format"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "biome.json",
        "bunfig.toml",
        "package.json",
        "turbo.json"
      ],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "package.json",
        "turbo.json",
        "pyrightconfig.json"
      ],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^test"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "package.json",
        "turbo.json"
      ],
      "outputs": []
    }
  }
}
