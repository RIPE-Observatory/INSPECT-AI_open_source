{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "organizeImports": {
    "enabled": true
  },
  "linter": {
    "rules": {
      "recommended": true
    }
  },
  "files": {
    "ignore": [
      "node_modules/**",
      "apps/ui/.next/**",
      "apps/ui/out/**",
      "apps/ui/storybook-static/**",
      "playwright-report/**",
      "test-results/**",
      "apps/ui/playwright-report/**",
      ".turbo/**"
    ]
  }
}
