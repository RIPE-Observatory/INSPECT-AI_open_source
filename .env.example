# INSPECT-AI reproducible local/paper mode
# Copy to .env and set OPENROUTER_API_KEY. Clerk auth is disabled by default.

OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_LLM_MODEL=google/gemini-3-flash-preview:nitro

DISABLE_AUTH=true
DEMO_REVIEWER_ID=inspect_demo_reviewer
NEXT_PUBLIC_DISABLE_AUTH=true

CHECKS_PROFILE=beta
NEXT_PUBLIC_CHECKS_PROFILE=beta

POSTGRES_USER=inspect_user
POSTGRES_PASSWORD=secure_password_123
POSTGRES_DB=inspect_ai
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://inspect_user:secure_password_123@postgres:5432/inspect_ai

REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

GROBID_SERVICE_URL=http://grobid:8070
GROBID_THREADS=4
GROBID_POOL_MAX_WAIT=120
PDF_MEMORY_LIMIT=1024
GROBID_CONTAINER_MEMORY=2g
GROBID_CONTAINER_CPUS=1.0

PUBPEER_API_URL=https://pubpeer.com/v3/publications
PUBPEER_DEV_KEY=PythonTest

LOG_LEVEL=INFO
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional: only needed if DISABLE_AUTH=false.
# CLERK_JWKS_URL=
# CLERK_ISSUER=
# CLERK_ALLOWED_AUDIENCES=
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=
# CLERK_JWT_TEMPLATE_NAME=backend
